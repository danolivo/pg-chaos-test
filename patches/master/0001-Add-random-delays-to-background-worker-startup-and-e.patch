From f1190040450513c603446b152d6e6c0fa8e0d16e Mon Sep 17 00:00:00 2001
From: "Andrei V. Lepikhov" <lepihov@gmail.com>
Date: Wed, 8 Apr 2026 09:27:00 +0200
Subject: [PATCH 1/9] Add random delays to background worker startup and exit

Introduce 1-50 ms random delays in BackgroundWorkerMain()
before invoking the worker entry function, before normal exit
(proc_exit(0)). Uses pg_prng
and is guarded by #ifndef NO_CHAOS to match the existing chaos mode
convention.

This helps expose race conditions in bgworker lifecycle during
regression testing.
---
 src/backend/postmaster/bgworker.c | 9 +++++++++
 src/include/common/pg_prng.h      | 2 ++
 2 files changed, 11 insertions(+)

diff --git a/src/backend/postmaster/bgworker.c b/src/backend/postmaster/bgworker.c
index 3914d22a514..2c7ca8ea234 100644
--- a/src/backend/postmaster/bgworker.c
+++ b/src/backend/postmaster/bgworker.c
@@ -14,6 +14,7 @@
 
 #include "access/parallel.h"
 #include "commands/repack.h"
+#include "common/pg_prng.h"
 #include "libpq/pqsignal.h"
 #include "miscadmin.h"
 #include "pgstat.h"
@@ -862,9 +863,17 @@ BackgroundWorkerMain(const void *startup_data, size_t startup_data_len)
 	/*
 	 * Now invoke the user-defined worker code
 	 */
+#ifdef CHAOS_MODE
+	/* Random delay (1-50 ms) before bgworker starts. */
+	pg_usleep((pg_prng_uint32(&pg_global_prng_state) % 50 + 1) * 1000);
+#endif
 	entrypt(worker->bgw_main_arg);
 
 	/* ... and if it returns, we're done */
+#ifdef CHAOS_MODE
+	/* Random delay (1-50 ms) before bgworker exits. */
+	pg_usleep((pg_prng_uint32(&pg_global_prng_state) % 50 + 1) * 1000);
+#endif
 	proc_exit(0);
 }
 
diff --git a/src/include/common/pg_prng.h b/src/include/common/pg_prng.h
index 259848fe9e3..f9c9d77abb8 100644
--- a/src/include/common/pg_prng.h
+++ b/src/include/common/pg_prng.h
@@ -11,6 +11,8 @@
 #ifndef PG_PRNG_H
 #define PG_PRNG_H
 
+#define CHAOS_MODE 1
+
