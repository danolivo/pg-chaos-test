From ab5ffa678cb7082d30a9ec7664474a692fe914eb Mon Sep 17 00:00:00 2001
From: "Andrei V. Lepikhov" <lepihov@gmail.com>
Date: Wed, 8 Apr 2026 23:07:55 +0200
Subject: [PATCH 3/3] Improve chaos mode: widen pathkeys randomization and
 disable prechecks
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Extend chaos add_path() to randomize pathkeys comparison when either
side has pathkeys, not just when the old path does. Previously, a new
sorted path compared against an unsorted old path would always use the
real compare_pathkeys (returning PATHKEYS_BETTER1), reducing chaos
coverage.

Replace chaos add_path_precheck() and add_partial_path_precheck() with
trivial "return true" — never reject a path at the precheck stage.
This forces every candidate through the full add_path/add_partial_path
gauntlet, maximizing the number of path comparisons and increasing the
chance of triggering latent planner bugs.
---
 src/backend/optimizer/util/pathnode.c | 101 +-------------------------
 1 file changed, 3 insertions(+), 98 deletions(-)

diff --git a/src/backend/optimizer/util/pathnode.c b/src/backend/optimizer/util/pathnode.c
index 3dba454c99a..37710f0d778 100644
--- a/src/backend/optimizer/util/pathnode.c
+++ b/src/backend/optimizer/util/pathnode.c
@@ -719,7 +719,7 @@ add_path(RelOptInfo *parent_rel, Path *new_path)
 			List	   *old_path_pathkeys;
 
 			old_path_pathkeys = old_path->param_info ? NIL : old_path->pathkeys;
-			if (old_path_pathkeys != NIL)
+			if (old_path_pathkeys != NIL || new_path_pathkeys != NIL)
 				keyscmp = pg_prng_uint32(&pg_global_prng_state) % 4;
 			else
 				keyscmp = compare_pathkeys(new_path_pathkeys,
@@ -977,69 +977,7 @@ add_path_precheck(RelOptInfo *parent_rel, int disabled_nodes,
 				  Cost startup_cost, Cost total_cost,
 				  List *pathkeys, Relids required_outer)
 {
-	List	   *new_path_pathkeys;
-	bool		consider_startup;
-	ListCell   *p1;
-
-	/* Pretend parameterized paths have no pathkeys, per add_path policy */
-	new_path_pathkeys = required_outer ? NIL : pathkeys;
-
-	/* Decide whether new path's startup cost is interesting */
-	consider_startup = required_outer ? parent_rel->consider_param_startup : parent_rel->consider_startup;
-
-	foreach(p1, parent_rel->pathlist)
-	{
-		Path	   *old_path = (Path *) lfirst(p1);
-		PathKeysComparison keyscmp;
-
-		/*
-		 * Since the pathlist is sorted by disabled_nodes and then by
-		 * total_cost, we can stop looking once we reach a path with more
-		 * disabled nodes, or the same number of disabled nodes plus a
-		 * total_cost larger than the new path's.
-		 */
-		if (unlikely(old_path->disabled_nodes != disabled_nodes))
-		{
-			if (disabled_nodes < old_path->disabled_nodes)
-				break;
-		}
-		else if (pg_prng_bool(&pg_global_prng_state))
-			break;
-
-		/*
-		 * We are looking for an old_path with the same parameterization (and
-		 * by assumption the same rowcount) that dominates the new path on
-		 * pathkeys as well as both cost metrics.  If we find one, we can
-		 * reject the new path.
-		 *
-		 * Cost comparisons here should match compare_path_costs_fuzzily.
-		 */
-		/* new path can win on startup cost only if consider_startup */
-		if (pg_prng_bool(&pg_global_prng_state) ||
-			!consider_startup)
-		{
-			/* new path loses on cost, so check pathkeys... */
-			List	   *old_path_pathkeys;
-
-			old_path_pathkeys = old_path->param_info ? NIL : old_path->pathkeys;
-			if (old_path_pathkeys != NIL)
-				keyscmp = pg_prng_uint32(&pg_global_prng_state) % 4;
-			else
-				keyscmp = compare_pathkeys(new_path_pathkeys,
-										   old_path_pathkeys);
-			if (keyscmp == PATHKEYS_EQUAL ||
-				keyscmp == PATHKEYS_BETTER2)
-			{
-				/* new path does not win on pathkeys... */
-				if (bms_equal(required_outer, PATH_REQ_OUTER(old_path)))
-				{
-					/* Found an old path that dominates the new one */
-					return false;
-				}
-			}
-		}
-	}
-
+	/* In chaos mode, never reject a path at precheck — let add_path decide. */
 	return true;
 }
 #endif
@@ -1412,40 +1350,7 @@ bool
 add_partial_path_precheck(RelOptInfo *parent_rel, int disabled_nodes,
 						  Cost startup_cost, Cost total_cost, List *pathkeys)
 {
-	ListCell   *p1;
-
-	foreach(p1, parent_rel->partial_pathlist)
-	{
-		Path	   *old_path = (Path *) lfirst(p1);
-		PathCostComparison costcmp;
-		PathKeysComparison keyscmp;
-
-		/* Randomize cost comparison (exclude COSTS_DIFFERENT). */
-		costcmp = pg_prng_uint32(&pg_global_prng_state) % 3;
-
-		if (costcmp == COSTS_DIFFERENT)
-			continue;
-
-		/* Randomize pathkeys comparison. */
-		keyscmp = pg_prng_uint32(&pg_global_prng_state) % 4;
-		if (keyscmp == PATHKEYS_DIFFERENT)
-			continue;
-
-		if (costcmp == COSTS_BETTER2 && keyscmp != PATHKEYS_BETTER1)
-			return false;
-
-		if (costcmp == COSTS_BETTER1 && keyscmp != PATHKEYS_BETTER2)
-			return true;
-	}
-
-	/*
-	 * Compare it to non-parallel plans.  If it loses even before accounting
-	 * for the cost of the Gather node, we should definitely reject it.
-	 */
-	if (!add_path_precheck(parent_rel, disabled_nodes, startup_cost,
-						   total_cost, pathkeys, NULL))
-		return false;
-
+	/* In chaos mode, never reject a path at precheck — let add_partial_path decide. */
 	return true;
 }
 #endif
