From 47af2a0d2ef72d1842eaff32b6c4ec1ac7942786 Mon Sep 17 00:00:00 2001
From: "Andrei V. Lepikhov" <lepihov@gmail.com>
Date: Sat, 11 Apr 2026 17:03:50 +0200
Subject: [PATCH 6/9] Add CHAOS_MODE early-return in truncate_useless_pathkeys

In chaos mode truncate_useless_pathkeys returns the full pathkey list
unchanged, preventing the planner from discarding sort keys it considers
redundant.  This keeps more paths alive and exercises wider plan space
during chaos testing.

Add the missing #include "common/pg_prng.h" that defines CHAOS_MODE;
without it the #ifdef is always false and the chaos branch is silently
dead.
---
 src/backend/optimizer/path/pathkeys.c | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/src/backend/optimizer/path/pathkeys.c b/src/backend/optimizer/path/pathkeys.c
index 5eb71635d15..bf582b0af76 100644
--- a/src/backend/optimizer/path/pathkeys.c
+++ b/src/backend/optimizer/path/pathkeys.c
@@ -18,6 +18,7 @@
 #include "postgres.h"
 
 #include "access/stratnum.h"
+#include "common/pg_prng.h"
 #include "catalog/pg_opfamily.h"
 #include "nodes/nodeFuncs.h"
 #include "optimizer/cost.h"
@@ -2205,6 +2206,10 @@ truncate_useless_pathkeys(PlannerInfo *root,
 	int			nuseful2;
 	int			ntotal = list_length(pathkeys);
 
+#ifdef CHAOS_MODE
+	return pathkeys;
+#endif
+
 	/*
 	 * Here we determine how many items in 'pathkeys' might be useful for
 	 * various Path sort ordering requirements the planner has.  Operations
@@ -2290,6 +2295,9 @@ truncate_useless_pathkeys(PlannerInfo *root,
 bool
 has_useful_pathkeys(PlannerInfo *root, RelOptInfo *rel)
 {
+#ifdef CHAOS_MODE
+	return true;
+#endif
 	if (rel->joininfo != NIL || rel->has_eclass_joins)
 		return true;			/* might be able to use pathkeys for merging */
 	if (root->query_pathkeys != NIL)
